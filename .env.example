POSTGRES_DB=trackflow_inventory
POSTGRES_USER=trackflow
POSTGRES_PASSWORD=replace-with-local-only-password
IDENTITY_JWT_PRIVATE_KEY=replace-with-local-private-key
IDENTITY_JWT_PUBLIC_KEY=replace-with-local-public-key
SEED_USER_UUID=
RESEND_API_KEY=
EMAIL_SENDER=no-reply@trackflow.example
TALENT_API_URL=https://playground.4geeks.com/tracker/api/v1
# Dedicated Prefect Server. Keep this digest independent from TRACKFLOW_IMAGE_TAG.
PREFECT_SERVER_IMAGE=prefecthq/prefect:3.7.8-python3.11@sha256:d4d142f1426ed0e8d7f48b3cc730f7b0469dcbcaf720959bb678f4cec3e5c3cc
PREFECT_DB_PASSWORD=replace-with-a-long-random-prefect-db-password
PREFECT_BACKUP_DB_PASSWORD=replace-with-a-distinct-read-only-prefect-backup-password
# Separate CONNECT-only role for the reporting worker's startup guard. It reads
# pg_catalog and nothing else, so it must not reuse the backup role's credential:
# the guard password lives in a long-running application worker.
PREFECT_GUARD_DB_PASSWORD=replace-with-a-distinct-connect-only-prefect-guard-password
PREFECT_API_REQUEST_TIMEOUT=30
PREFECT_RUN_RETENTION_DAYS=30
PREFECT_BACKUP_R2_BUCKET=
PREFECT_BACKUP_R2_ENDPOINT=
PREFECT_BACKUP_R2_ACCESS_KEY_ID=
PREFECT_BACKUP_R2_SECRET_ACCESS_KEY=
PREFECT_BACKUP_RETENTION_DAYS=7
PREFECT_DB_DISK_WARNING_MB=1024
REPORTING_HEARTBEAT_SECONDS=60
REPORTING_RUN_TIMEOUT_SECONDS=1800
REPORTING_STAGE_TIMEOUT_EXTRACT_SECONDS=300
REPORTING_STAGE_TIMEOUT_TRANSFORM_SECONDS=300
REPORTING_STAGE_TIMEOUT_LOAD_SECONDS=300
