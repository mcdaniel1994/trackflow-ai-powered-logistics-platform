# Disposable local PostgreSQL from compose.yml. Replace the password after copying.
POSTGRES_DB=trackflow_inventory
POSTGRES_USER=trackflow
POSTGRES_PASSWORD=replace-with-local-only-password
DATABASE_URL=postgresql+psycopg2://trackflow:replace-with-local-only-password@127.0.0.1:55432/trackflow_inventory

# Trusted browser origins only; credentials are never paired with a wildcard origin.
CENTRAL_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Identity signs access tokens; Central API receives only the verification key.
IDENTITY_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace-with-local-identity-public-key\n-----END PUBLIC KEY-----
IDENTITY_JWT_ALGORITHM=RS256
IDENTITY_JWT_ISSUER=trackflow-identity
IDENTITY_JWT_AUDIENCE=trackflow-backoffice

# Must be an existing local Identity user UUID before running the seed command.
SEED_USER_UUID=
